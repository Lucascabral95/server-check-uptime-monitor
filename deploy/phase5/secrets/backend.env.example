NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://servercheck:replace-with-postgres-password@postgres:5432/servercheck?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-different-strong-random-password
SECRET_JWT=replace-with-a-long-random-secret
MONITOR_SECRETS_KEY=replace-with-32-byte-base64url-key
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/replace-user-pool-id
COGNITO_CLIENT_ID=replace-with-cognito-client-id
MY_URL_FRONTEND=https://status.example.com
OTEL_ENABLED=false
OTEL_SERVICE_NAME=server-check-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
