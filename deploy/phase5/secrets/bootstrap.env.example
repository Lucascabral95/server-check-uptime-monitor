POSTGRES_USER=servercheck
POSTGRES_DB=servercheck
POSTGRES_PASSWORD=replace-with-url-safe-random-password
REDIS_PASSWORD=replace-with-different-random-password
SECRET_JWT=replace-with-long-random-secret
MONITOR_SECRETS_KEY=replace-with-32-byte-base64url-key
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=alerts@example.com
# Optional Gmail fallback. Leave both empty to use SES only.
GMAIL_APP_USER=
GMAIL_APP_PASSWORD=
GRAFANA_ADMIN_PASSWORD=replace-with-long-random-grafana-password
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
