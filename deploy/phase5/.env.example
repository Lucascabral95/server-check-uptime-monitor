# Copy this file to deploy/phase5/.env on the production host.
# It contains deployment configuration, not private credentials.
PUBLIC_ORIGIN=https://replace-with-cloudfront-domain.cloudfront.net
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_replace-user-pool-id
NEXT_PUBLIC_COGNITO_CLIENT_ID=replace-with-cognito-client-id
APP_VERSION=git-sha-or-release-version

# Keep tracing enabled in production so Tempo receives application spans.
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
