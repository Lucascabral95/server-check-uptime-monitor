generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  PENDING
  UP
  DOWN
  DEGRADED
  PAUSED
  MAINTENANCE
}

enum MonitorType {
  HTTP
  SSL
  HEARTBEAT
}

enum Role {
  ADMIN
  USER
  GUEST
}

enum IncidentStatus {
  ONGOING
  RESOLVED
}

enum CheckRunStatus {
  PROCESSING
  SUCCEEDED
  FAILED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum WorkspacePlan {
  FREE
  PRO
  BUSINESS
}

enum AggregateGranularity {
  HOURLY
  DAILY
}

enum NotificationChannelType {
  EMAIL
  SLACK
  WEBHOOK
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum IncidentLifecycle {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum ProbeAssignmentStatus {
  PENDING
  LEASED
  COMPLETED
  FAILED
}

model User {
  id              String                @id @default(uuid())
  cognitoSub      String?               @unique @map("cognito_sub")
  email           String                @unique
  role            Role                  @default(USER)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  monitors        Monitor[]
  ownedWorkspaces Workspace[]           @relation("WorkspaceOwner")
  memberships     WorkspaceMembership[]
  auditLogs       AuditLog[]
  invitations     Invitation[]
  acknowledgedIncidents Incident[] @relation("IncidentAcknowledgedBy")
  incidentComments IncidentComment[]
  timelineEvents IncidentTimeline[] @relation("IncidentTimelineActor")

  @@map("users")
}

model Workspace {
  id          String                @id @default(uuid())
  name        String
  slug        String                @unique
  plan        WorkspacePlan         @default(FREE)
  ownerId     String                @map("owner_id")
  owner       User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships WorkspaceMembership[]
  projects    Project[]
  monitors    Monitor[]
  incidents   Incident[]
  invitations Invitation[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  notificationChannels NotificationChannel[]
  alertPolicies AlertPolicy[]
  statusPages StatusPage[]
  probeAgents ProbeAgent[]
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMembership {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
  @@map("workspace_memberships")
}

model Project {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  slug        String
  description String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  monitors    Monitor[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, slug])
  @@index([workspaceId, createdAt])
  @@map("projects")
}

model Invitation {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  email       String
  role        WorkspaceRole @default(VIEWER)
  tokenHash   String        @unique @map("token_hash")
  expiresAt   DateTime      @map("expires_at")
  acceptedAt  DateTime?     @map("accepted_at")
  invitedById String        @map("invited_by_id")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User          @relation(fields: [invitedById], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([workspaceId, email, acceptedAt])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  prefix      String
  keyHash     String    @unique @map("key_hash")
  scopes      Json
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId, revokedAt])
  @@map("workspace_api_keys")
}

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  actorUserId String?   @map("actor_user_id")
  action      String
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id")
  metadata    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, entityType, entityId])
  @@map("audit_logs")
}

model Monitor {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  workspaceId String? @map("workspace_id")
  projectId   String? @map("project_id")
  name        String
  url         String
  frequency   Int     @default(60)

  isActive                 Boolean     @default(true) @map("is_active")
  nextCheck                DateTime    @default(now()) @map("next_check")
  lastCheck                DateTime?   @map("last_check")
  status                   Status      @default(PENDING)
  monitorType              MonitorType @default(HTTP) @map("monitor_type")
  config                   Json        @default("{}")
  consecutiveFailures      Int         @default(0) @map("consecutive_failures")
  consecutiveSuccesses     Int         @default(0) @map("consecutive_successes")
  heartbeatSecretHash      String?     @unique @map("heartbeat_secret_hash")
  heartbeatIntervalSeconds Int?        @map("heartbeat_interval_seconds")
  heartbeatGraceSeconds    Int?        @map("heartbeat_grace_seconds")
  heartbeatLastReceivedAt  DateTime?   @map("heartbeat_last_received_at")
  maintenanceUntil         DateTime?   @map("maintenance_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  logs         PingLog[]
  incidents    Incident[]
  probeResults ProbeResult[]
  maintenanceWindows MaintenanceWindow[]
  aggregates MonitorAggregate[]
  notificationDeliveries NotificationDelivery[]
  alertPolicies AlertPolicy[]
  statusPageComponents StatusPageComponent[]
  sloTargets SloTarget[]
  probeAssignments ProbeAssignment[]

  // findAll() (uptime.service.ts) siempre filtra por userId y ordena por
  // createdAt; getStatsByUserId() siempre filtra por userId+isActive(+status).
  // El polling por nextCheck fue reemplazado por jobs recurrentes de BullMQ,
  // así que el índice viejo [isActive, nextCheck] no lo usa ninguna query.
  @@index([userId, createdAt])
  @@index([userId, isActive, status])
  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([monitorType, isActive])
  @@map("monitors")
}

model MaintenanceWindow {
  id              String   @id @default(uuid())
  monitorId       String   @map("monitor_id")
  daysOfWeek      Int[]    @map("days_of_week")
  startMinute     Int      @map("start_minute")
  durationMinutes Int      @map("duration_minutes")
  timezone        String   @default("UTC")
  enabled         Boolean  @default(true)
  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([monitorId, enabled])
  @@map("maintenance_windows")
}

model MonitorAggregate {
  id              String             @id @default(uuid())
  monitorId       String             @map("monitor_id")
  granularity     AggregateGranularity
  bucketStart     DateTime           @map("bucket_start")
  checks          Int                @default(0)
  successes       Int                @default(0)
  failures        Int                @default(0)
  totalDurationMs BigInt             @default(0) @map("total_duration_ms")
  downtimeMs      BigInt             @default(0) @map("downtime_ms")
  monitor         Monitor            @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([monitorId, granularity, bucketStart])
  @@index([monitorId, granularity, bucketStart(sort: Desc)])
  @@map("monitor_aggregates")
}

model PingLog {
  id         String   @id @default(uuid())
  monitorId  String   @map("monitor_id")
  runId      String?  @unique @map("run_id")
  statusCode Int      @map("status_code")
  durationMs Int      @map("duration_ms")
  error      String?
  timestamp  DateTime @default(now())
  success    Boolean  @default(false)

  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([monitorId, timestamp(sort: Desc)])
  @@index([monitorId, success])
  @@map("ping_logs")
}

// Durable execution record. `runId` is stable across BullMQ retries, so a
// retry cannot create a second result for the same check execution.
model CheckRun {
  id          String         @id @default(uuid())
  runId       String         @map("run_id")
  region      String         @default("primary")
  monitorId   String         @map("monitor_id")
  status      CheckRunStatus @default(PROCESSING)
  statusCode  Int            @map("status_code")
  durationMs  Int            @default(0) @map("duration_ms")
  success     Boolean        @default(false)
  error       String?
  startedAt   DateTime       @default(now()) @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@unique([runId, region])
  @@index([monitorId, startedAt(sort: Desc)])
  @@index([status, startedAt])
  @@map("check_runs")
}

model ProbeResult {
  id         String   @id @default(uuid())
  runId      String   @map("run_id")
  region     String
  monitorId  String   @map("monitor_id")
  success    Boolean
  statusCode Int      @map("status_code")
  durationMs Int      @map("duration_ms")
  error      String?
  checkedAt  DateTime @default(now()) @map("checked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@unique([runId, region])
  @@index([monitorId, checkedAt(sort: Desc)])
  @@map("probe_results")
}

// No tiene FK a Monitor a propÃ³sito: al borrar un monitor, el evento debe
// sobrevivir para retirar su job repetitivo de BullMQ.
model MonitorScheduleOutbox {
  id          String    @id @default(uuid())
  monitorId   String    @map("monitor_id")
  attempts    Int       @default(0)
  availableAt DateTime  @default(now()) @map("available_at")
  lockedAt    DateTime? @map("locked_at")
  lockedUntil DateTime? @map("locked_until")
  lockedBy    String?   @map("locked_by")
  processedAt DateTime? @map("processed_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([processedAt, availableAt, lockedUntil])
  @@index([monitorId])
  @@map("monitor_schedule_outbox")
}

// Se escribe desde uptime.processor.ts en cada transición UP<->DOWN del
// monitor (dentro de la misma transacción que el update de status), NO se
// deriva escaneando ping_logs. Ver getIncidents/getIncidentsByUserId en
// uptime.service.ts, que antes reconstruían esto con un findMany sin límite
// por cada monitor.
model Incident {
  id              String         @id @default(uuid())
  monitorId       String         @map("monitor_id")
  // Denormalizado a propósito: permite paginar/ordenar incidentes de TODOS
  // los monitores de un usuario con un único where:{userId}, en vez de un
  // IN (...) sobre la lista de monitores. Los monitores no cambian de
  // dueño, así que este valor es efectivamente inmutable.
  userId          String         @map("user_id")
  workspaceId     String?        @map("workspace_id")
  status          IncidentStatus @default(ONGOING)
  startedAt       DateTime       @map("started_at")
  endedAt         DateTime?      @map("ended_at")
  firstStatusCode Int?           @map("first_status_code")
  firstError      String?        @map("first_error")
  lastError       String?        @map("last_error")
  affectedChecks  Int            @default(1) @map("affected_checks")
  severity        AlertSeverity  @default(CRITICAL)
  lifecycle       IncidentLifecycle @default(INVESTIGATING)
  acknowledgedAt  DateTime?      @map("acknowledged_at")
  acknowledgedById String?       @map("acknowledged_by_id")

  monitor   Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acknowledgedBy User? @relation("IncidentAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  comments IncidentComment[]
  timeline IncidentTimeline[]
  notificationDeliveries NotificationDelivery[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([monitorId, startedAt(sort: Desc)])
  @@index([userId, startedAt(sort: Desc)])
  @@index([userId, status])
  @@index([workspaceId, startedAt(sort: Desc)])
  @@map("incidents")
}

model NotificationChannel {
  id String @id @default(uuid())
  workspaceId String @map("workspace_id")
  name String
  type NotificationChannelType
  config Json
  enabled Boolean @default(true)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]
  policies AlertPolicy[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([workspaceId, enabled])
  @@map("notification_channels")
}

model AlertPolicy {
  id String @id @default(uuid())
  workspaceId String @map("workspace_id")
  name String
  severity AlertSeverity @default(CRITICAL)
  monitorIds Json @map("monitor_ids")
  cooldownSeconds Int @default(300) @map("cooldown_seconds")
  recoveryEnabled Boolean @default(true) @map("recovery_enabled")
  enabled Boolean @default(true)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  monitorId String? @map("monitor_id")
  monitor Monitor? @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  channels NotificationChannel[]
  deliveries NotificationDelivery[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([workspaceId, enabled])
  @@map("alert_policies")
}

model NotificationDelivery {
  id String @id @default(uuid())
  channelId String @map("channel_id")
  policyId String? @map("policy_id")
  monitorId String? @map("monitor_id")
  incidentId String? @map("incident_id")
  idempotencyKey String @unique @map("idempotency_key")
  status NotificationDeliveryStatus @default(PENDING)
  attempts Int @default(0)
  nextAttemptAt DateTime @default(now()) @map("next_attempt_at")
  payload Json
  lastError String? @map("last_error")
  sentAt DateTime? @map("sent_at")
  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  policy AlertPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  monitor Monitor? @relation(fields: [monitorId], references: [id], onDelete: SetNull)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([status, nextAttemptAt])
  @@map("notification_deliveries")
}

model IncidentComment {
  id String @id @default(uuid())
  incidentId String @map("incident_id")
  authorId String @map("author_id")
  body String
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  @@index([incidentId, createdAt])
  @@map("incident_comments")
}

model IncidentTimeline {
  id String @id @default(uuid())
  incidentId String @map("incident_id")
  actorId String? @map("actor_id")
  event String
  metadata Json?
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor User? @relation("IncidentTimelineActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  @@index([incidentId, createdAt])
  @@map("incident_timeline")
}

model StatusPage {
  id String @id @default(uuid())
  workspaceId String @map("workspace_id")
  name String
  slug String @unique
  description String?
  isPublished Boolean @default(false) @map("is_published")
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  components StatusPageComponent[]
  subscribers StatusPageSubscriber[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([workspaceId, isPublished])
  @@map("status_pages")
}

model StatusPageComponent {
  id String @id @default(uuid())
  statusPageId String @map("status_page_id")
  monitorId String @map("monitor_id")
  name String
  position Int @default(0)
  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  @@unique([statusPageId, monitorId])
  @@index([statusPageId, position])
  @@map("status_page_components")
}

model StatusPageSubscriber {
  id String @id @default(uuid())
  statusPageId String @map("status_page_id")
  email String
  tokenHash String @unique @map("token_hash")
  confirmedAt DateTime? @map("confirmed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  statusPage StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  @@unique([statusPageId, email])
  @@map("status_page_subscribers")
}

model ProbeAgent {
  id String @id @default(uuid())
  workspaceId String? @map("workspace_id")
  name String
  region String @unique
  version String
  tokenHash String @unique @map("token_hash")
  enabled Boolean @default(true)
  lastSeenAt DateTime? @map("last_seen_at")
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  heartbeats AgentHeartbeat[]
  assignments ProbeAssignment[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([enabled, lastSeenAt])
  @@map("probe_agents")
}

model AgentHeartbeat {
  id String @id @default(uuid())
  agentId String @map("agent_id")
  version String
  queueLagMs Int @default(0) @map("queue_lag_ms")
  capacity Int @default(0)
  receivedAt DateTime @default(now()) @map("received_at")
  agent ProbeAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([agentId, receivedAt(sort: Desc)])
  @@map("agent_heartbeats")
}

model ProbeAssignment {
  id String @id @default(uuid())
  agentId String @map("agent_id")
  runId String @map("run_id")
  monitorId String @map("monitor_id")
  url String
  method String @default("GET")
  timeoutMs Int @default(10000) @map("timeout_ms")
  status ProbeAssignmentStatus @default(PENDING)
  leasedUntil DateTime? @map("leased_until")
  completedAt DateTime? @map("completed_at")
  agent ProbeAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([runId, agentId])
  @@index([agentId, status, leasedUntil])
  @@map("probe_assignments")
}

model SloTarget {
  id String @id @default(uuid())
  monitorId String @map("monitor_id")
  target Decimal @db.Decimal(5, 3)
  periodDays Int @default(30) @map("period_days")
  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([monitorId, periodDays])
  @@map("slo_targets")
}

// NOTA para quien genere la migración (`npx prisma migrate dev --create-only
// --name add_incidents_table`): Prisma no puede expresar índices parciales.
// Antes de aplicar la migración generada, agregarle a mano esta línea (es
// lo que garantiza que solo pueda existir UN incidente ONGOING por monitor,
// y es la base de la escritura idempotente bajo concurrencia):
//
//   CREATE UNIQUE INDEX "incidents_one_ongoing_per_monitor"
//     ON "incidents" ("monitor_id") WHERE "status" = 'ONGOING';
