PORT=4000
NODE_ENV=development

SECRET_JWT=thisismysecret
JWT_EXPIRES_IN=60d

MY_URL_FRONTEND=http://localhost:3000

# AWS Cognito (auth) — deben coincidir con NEXT_PUBLIC_COGNITO_* en apps/web/.env
# COGNITO_ISSUER = https://cognito-idp.<AWS_REGION>.amazonaws.com/<user-pool-id>
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DB
POSTGRES_USER=servercheck
POSTGRES_PASSWORD=servercheck123
POSTGRES_DB=servercheck_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://servercheck:servercheck123@localhost:5432/servercheck_dev?schema=public
#DATABASE_URL=postgresql://servercheck:servercheck123@postgres:5432/servercheck_dev?schema=public

# Tuning del pool de conexiones (opcionales, tienen default)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Graceful shutdown: cuánto esperar tras marcar el readiness en 503 antes de
# empezar a cerrar recursos, para darle tiempo al load balancer de drenar
# tráfico (opcional, tiene default)
SHUTDOWN_DRAIN_DELAY_MS=3000

# Cuántos jobs de chequeo procesa el worker de BullMQ en paralelo (opcional,
# tiene default). Seguro de subir gracias al CAS transaccional en el
# processor: un host caído ya no bloquea los checks de los demás monitores.
WORKER_CONCURRENCY=5

# REDIS
#REDIS_HOST="redis" # Para production
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=myredisconfig

# AWS para servicio SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxx
AWS_SES_FROM_EMAIL=your_personal_email@gmail.com

# Nodemailer (fallback si falla SES)
GMAIL_APP_USER=your_personal_email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Email Global
SEND_EMAIL_NODEMAILER_SES=your_personal_email@gmail.com