{
  "name": "server-check-app",
  "version": "1.0.0",
  "private": true,
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "^10.8.2",
      "onFail": "warn"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "cd apps/backend-uptime && npm run start:dev",
    "dev:frontend": "cd apps/web && npm run dev",
    "build-test:frontend": "cd apps/web && npm run build && npm test",
    "build-test:backend": "cd apps/backend-uptime && npm run build && npm test",
    "build-test:full-project": "npm run build-test:frontend && npm run build-test:backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "docker:backend": "cd apps/backend-uptime && docker-compose up --build -d backend-uptime",
    "build:start:frontend": "cd apps/web && npm run build && npm start",
    "start:frontend": "cd apps/web && npm start",
    "security:audit": "npm audit --audit-level=high",
    "deploy:aws": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy-aws.ps1"
  },
  "keywords": [],
  "author": "Lucas Cabral Dev",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "brace-expansion": "^1.1.13",
    "axios": "^1.18.1",
    "turbo": "^2.7.4",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "react-hook-form": "^7.71.1"
  },
  "overrides": {
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "next": {
      "postcss": "^8.5.16"
    }
  }
}
